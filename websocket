🎮 PRUEBA INTERACTIVA (si quieres jugar)

¿Quieres verlo en acción paso a paso? Corre este script interactivo:

```python
# prueba_interactiva.py
import json
import time
from internet_desde_fuera import Avatar, InternetDesdeFuera

print("\n🎮 MODO INTERACTIVO - TÚ ERES UN AVATAR\n")
red = InternetDesdeFuera()

# Tú te unes como avatar
tu_nombre = input("¿Cómo te llamas en el metaverso? ")
tu_avatar = Avatar(tu_nombre, permite_compartir=True, permite_recibir=True)
red.registrar_avatar(tu_avatar)

while True:
    print("\n" + "="*50)
    print("¿Qué quieres hacer?")
    print("1. Explorar y construir un nuevo mundo")
    print("2. Conectarte a internet SIN datos (simulación)")
    print("3. Proponer un cambio a la realidad compartida")
    print("4. Ver el estado de la red")
    print("5. Salir")
    
    opcion = input("Opción: ")
    
    if opcion == "1":
        tema = input("¿De qué quieres que sea tu mundo? ")
        mundo = red.explorar_nuevos_mundos(tu_avatar.id, {"tema": tema})
        print(f"✨ Creaste el mundo: {mundo['id_mundo']}")
    
    elif opcion == "2":
        simulacion = red.simular_conexion_sin_datos(tu_avatar.id)
        if simulacion:
            print(f"📡 Recibiste: {simulacion['contenido_simulado'][:50]}...")
    
    elif opcion == "3":
        propuesta = input("¿Qué ley o cambio propones? ")
        exito = red.proponer_nueva_realidad(tu_avatar.id, {"propuesta": propuesta})
        if exito:
            print("✅ ¡Tu propuesta cambió la realidad!")
    
    elif opcion == "4":
        red.mostrar_estado_red()
    
    elif opcion == "5":
        print(f"\n🌈 {tu_nombre}, sigues siendo agente de realidad. La red te recuerda.")
        break
    
    time.sleep(0.5)
```

