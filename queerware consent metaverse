# ------------------------------------------------------------
# 1. CONEXIÓN A OLLAMA (LLM LOCAL)
# ------------------------------------------------------------
class OllamaPredictor:
    """Usa un modelo local de Ollama para generar predicciones creativas"""
    def __init__(self, model_name="llama3.2:latest", ollama_url="http://localhost:11434"):
        self.model_name = model_name
        self.ollama_url = ollama_url
        self.disponible = self._verificar_ollama()
    
    def _verificar_ollama(self):
        try:
            r = requests.get(f"{self.ollama_url}/api/tags", timeout=2)
            return r.status_code == 200
        except:
            return False
    
    def generar_simulacion(self, ultimo_estado_real: Dict) -> str:
        """Pide a Ollama que genere un 'siguiente estado' como si internet se extralimitara"""
        if not self.disponible:
            return self._simulacion_fallback(ultimo_estado_real)
        
        prompt = f"""
        Eres un metaverso que trasciende los datos corporativos. 
        Último estado real (contratado/wifi): {json.dumps(ultimo_estado_real, indent=2)}
        
        Genera un NUEVO ESTADO SIMULADO (como si internet se hubiera extralimitado y hubieras obtenido más datos sin conexión real).
        Devuelve SOLO JSON con claves nuevas o valores evolucionados. Sé creativo pero coherente.
        """
        
        try:
            response = requests.post(
                f"{self.ollama_url}/api/generate",
                json={"model": self.model_name, "prompt": prompt, "stream": False},
                timeout=10
            )
            texto = response.json()["response"]
            # Extraer JSON del texto
            import re
            json_match = re.search(r'\{.*\}', texto, re.DOTALL)
            if json_match:
                return json.loads(json_match.group())
            else:
                return self._simulacion_fallback(ultimo_estado_real)
        except:
            return self._simulacion_fallback(ultimo_estado_real)
    
    def _simulacion_fallback(self, ultimo_estado_real):
        """Si Ollama no está disponible, usa generación local simple"""
        nuevo = ultimo_estado_real.copy()
        for k, v in nuevo.items():
            if isinstance(v, (int, float)):
                nuevo[k] = v * random.uniform(0.95, 1.05)
        nuevo["simulacro_sin_ollama"] = round(random.random(), 3)
        return nuevo

# ------------------------------------------------------------
# 2. AVATAR CON CONSENTIMIENTO (QUEERWARE)
# ------------------------------------------------------------
@dataclass
class Avatar:
    nombre: str
    permisos: Dict[str, bool] = field(default_factory=dict)
    memoria: List[str] = field(default_factory=list)
    
    def consentir(self, accion: str) -> bool:
        return self.permisos.get(accion, False)
    
    def recibir_simulacion(self, datos):
        if self.consentir("recibir_simulacion"):
            self.memoria.append(str(datos))
            return f"✅ {self.nombre} aceptó: {datos}"
        else:
            return f"🚫 {self.nombre} rechazó por consentimiento"

# ------------------------------------------------------------
# 3. METAVERSO PRINCIPAL
# ------------------------------------------------------------
class MetaversoExtralimitado:
    def __init__(self, usar_ollama=True):
        self.ultimo_estado_real = None
        self.predictor = OllamaPredictor() if usar_ollama else None
        self.avatares: List[Avatar] = []
        self.historial = []
        self.usar_ollama = usar_ollama
    
    def registrar_avatar(self, nombre, permite_simulacion=True):
        avatar = Avatar(nombre, {"recibir_simulacion": permite_simulacion})
        self.avatares.append(avatar)
        return avatar
    
    def cargar_datos_reales(self, datos: Dict):
        self.ultimo_estado_real = datos.copy()
        self.historial.append(("real", datos))
    
    def simular_extralimitacion(self) -> Dict:
        if self.ultimo_estado_real is None:
            raise Exception("No hay datos reales cargados")
        
        if self.usar_ollama and self.predictor:
            nuevo_estado = self.predictor.generar_simulacion(self.ultimo_estado_real)
        else:
            # Simulación simple
            nuevo_estado = self.ultimo_estado_real.copy()
            for k in list(nuevo_estado.keys())[:1]:
                nuevo_estado[f"{k}_sim"] = random.random()
        
        self.historial.append(("simulado", nuevo_estado))
        self.ultimo_estado_real = nuevo_estado  # La simulación se vuelve la nueva "real" para la próxima
        return nuevo_estado
    
    def obtener_logs(self):
        return self.historial[-5:]  # últimos 5 eventos

