# 4. INTERFAZ GRÁFICA (TKINTER)
# ------------------------------------------------------------
class AppQueerWare:
    def __init__(self, root):
        self.root = root
        self.root.title("🌀 Metaverso Extralimitado · Deep AI QueerWare")
        self.root.geometry("800x600")
        self.root.configure(bg="#1e1e2f")
        
        self.metaverso = MetaversoExtralimitado(usar_ollama=True)
        
        # Datos de ejemplo iniciales
        self.datos_ejemplo = {
            "temperatura_servidor": 23.5,
            "usuarios_conectados": 128,
            "ancho_banda_mbps": 88.2,
            "contrato_activo": "Premium",
            "ultima_actualizacion": "2025-04-01"
        }
        
        self._crear_widgets()
        self._actualizar_log()
    
    def _crear_widgets(self):
        # Título
        titulo = tk.Label(self.root, text="🌌 METAVERSO EXTRALIMITADO", font=("Arial", 18, "bold"),
                          fg="#ff79c6", bg="#1e1e2f")
        titulo.pack(pady=10)
        
        # Frame de avatares
        frame_avatares = tk.LabelFrame(self.root, text="🤖 Avatares con Consentimiento (QueerWare)", 
                                       bg="#282a36", fg="white", font=("Arial", 10, "bold"))
        frame_avatares.pack(fill="x", padx=10, pady=5)
        
        self.avatar_listbox = tk.Listbox(frame_avatares, height=4, bg="#44475a", fg="white")
        self.avatar_listbox.pack(fill="x", padx=5, pady=5)
        
        btn_agregar_avatar = tk.Button(frame_avatares, text="➕ Agregar Avatar (consiente)", 
                                       command=self.agregar_avatar, bg="#50fa7b", fg="black")
        btn_agregar_avatar.pack(pady=2)
        
        btn_avatar_no_consiente = tk.Button(frame_avatares, text="🚫 Agregar Avatar (NO consiente)", 
                                            command=self.agregar_avatar_no_consiente, bg="#ff5555", fg="white")
        btn_avatar_no_consiente.pack(pady=2)
        
        # Frame de datos reales
        frame_datos = tk.LabelFrame(self.root, text="📡 Última actualización CON datos contratados/wifi", 
                                    bg="#282a36", fg="white")
        frame_datos.pack(fill="x", padx=10, pady=5)
        
        self.txt_datos_reales = tk.Text(frame_datos, height=6, bg="#44475a", fg="white", wrap=tk.WORD)
        self.txt_datos_reales.pack(fill="both", padx=5, pady=5)
        self.txt_datos_reales.insert(tk.END, json.dumps(self.datos_ejemplo, indent=2))
        
        btn_cargar = tk.Button(frame_datos, text="📥 Cargar estos datos como 'contrato real'", 
                               command=self.cargar_datos_reales, bg="#8be9fd", fg="black")
        btn_cargar.pack(pady=2)
        
        # Botón de simulación
        btn_simular = tk.Button(self.root, text="🌀 SIMULAR EXTRALIMITACIÓN (sin conexión real)", 
                                command=self.simular, font=("Arial", 12, "bold"),
                                bg="#ffb86c", fg="black", pady=5)
        btn_simular.pack(pady=10)
        
        # Log de eventos
        frame_log = tk.LabelFrame(self.root, text="📜 Historial de extralimitaciones", bg="#282a36", fg="white")
        frame_log.pack(fill="both", expand=True, padx=10, pady=5)
        
        self.log_text = scrolledtext.ScrolledText(frame_log, height=12, bg="#44475a", fg="#f8f8f2", wrap=tk.WORD)
        self.log_text.pack(fill="both", expand=True, padx=5, pady=5)
        
        # Estado de Ollama
        self.label_ollama = tk.Label(self.root, text="🔍 Verificando Ollama...", bg="#1e1e2f", fg="#f1fa8c")
        self.label_ollama.pack(pady=5)
        self._verificar_ollama_estado()
    
    def _verificar_ollama_estado(self):
        try:
            r = requests.get("http://localhost:11434/api/tags", timeout=2)
            if r.status_code == 200:
                self.label_ollama.config(text="✅ Ollama conectado · IA local activa", fg="#50fa7b")
            else:
                self.label_ollama.config(text="⚠️ Ollama no responde · Usando fallback simple", fg="#ffb86c")
        except:
            self.label_ollama.config(text="❌ Ollama no disponible · Instala ollama.com", fg="#ff5555")
    
    def agregar_avatar(self):
        nombre = f"Avatar_{len(self.metaverso.avatares)+1}"
        self.metaverso.registrar_avatar(nombre, permite_simulacion=True)
        self.avatar_listbox.insert(tk.END, f"🤝 {nombre} (consiente)")
    
    def agregar_avatar_no_consiente(self):
        nombre = f"Avatar_{len(self.metaverso.avatares)+1}"
        self.metaverso.registrar_avatar(nombre, permite_simulacion=False)
        self.avatar_listbox.insert(tk.END, f"🚫 {nombre} (NO consiente)")
    
    def cargar_datos_reales(self):
        try:
            datos = json.loads(self.txt_datos_reales.get("1.0", tk.END).strip())
            self.metaverso.cargar_datos_reales(datos)
            messagebox.showinfo("Éxito", "Datos contratados cargados. Ahora puedes simular extralimitaciones.")
            self._actualizar_log()
        except Exception as e:
            messagebox.showerror("Error", f"JSON inválido: {e}")
    
    def simular(self):
        if self.metaverso.ultimo_estado_real is None:
            messagebox.showwarning("Sin datos", "Primero carga datos reales (simulando un contrato o wifi).")
            return
        
        def tarea_simular():
            try:
                nuevo = self.metaverso.simular_extralimitacion()
                self.root.after(0, lambda: self._mostrar_simulacion(nuevo))
            except Exception as e:
                self.root.after(0, lambda: messagebox.showerror("Error", str(e)))
        
        threading.Thread(target=tarea_simular, daemon=True).start()
    
    def _mostrar_simulacion(self, nuevo_estado):
        # Notificar a avatares
        for avatar in self.metaverso.avatares:
            resultado = avatar.recibir_simulacion(nuevo_estado)
            self.log_text.insert(tk.END, f"{resultado}\n")
        
        self.log_text.insert(tk.END, f"\n🌀 NUEVA EXTRALIMITACIÓN SIMULADA:\n{json.dumps(nuevo_estado, indent=2)}\n")
        self.log_text.insert(tk.END, "─" * 50 + "\n")
        self.log_text.see(tk.END)
        
        # Actualizar datos reales mostrados (la simulación se vuelve el nuevo estado base)
        self.txt_datos_reales.delete("1.0", tk.END)
        self.txt_datos_reales.insert(tk.END, json.dumps(nuevo_estado, indent=2))
    
    def _actualizar_log(self):
        self.log_text.insert(tk.END, "✅ Sistema listo. Carga datos reales y simula.\n")

